---
import {
  SITE_NAME,
  SITE_DOMAIN,
  ACQUISITION_EMAIL,
  DISCLAIMER,
  acquisitionMailto,
} from '../lib/constants';

const year = new Date().getFullYear();
const mailto = acquisitionMailto();
---

<footer class="border-t border-ink/10 bg-mist/40">
  <!-- Domain acquisition CTA -->
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-14 md:py-20">
    <div
      class="relative overflow-hidden rounded-[2rem] border border-ink/10 bg-ink text-paper p-8 md:p-12"
    >
      <div
        class="absolute -top-28 -right-20 w-72 h-72 rounded-full bg-teal/30 blur-3xl pointer-events-none"
        aria-hidden="true"
      >
      </div>
      <div
        class="absolute -bottom-24 -left-16 w-56 h-56 rounded-full bg-coral/20 blur-3xl pointer-events-none"
        aria-hidden="true"
      >
      </div>

      <div class="relative grid md:grid-cols-12 gap-10 items-center">
        <div class="md:col-span-7 space-y-4">
          <p
            class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.22em] font-bold text-teal"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-teal animate-pulse"></span>
            Domain available for acquisition
          </p>
          <h2 class="font-display text-3xl sm:text-4xl tracking-tight leading-tight text-paper">
            Acquire <span class="text-teal">{SITE_DOMAIN}</span>
          </h2>
          <p class="text-paper/65 max-w-xl text-sm md:text-base leading-relaxed">
            A memorable, brandable domain for products, media, or experiences built
            around human connection. Confidential inquiries welcome — flexible
            transfer and escrow options available.
          </p>
        </div>

        <div class="md:col-span-5 flex flex-col sm:flex-row md:flex-col gap-3 md:items-stretch">
          <a
            href={mailto}
            class="group w-full text-center px-8 py-4 bg-teal text-paper font-bold rounded-2xl hover:bg-teal-deep transition-colors flex items-center justify-center gap-2"
          >
            <span>Request acquisition terms</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-5 h-5 group-hover:translate-x-0.5 transition-transform"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M5 12h14m-7-7l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href={`mailto:${ACQUISITION_EMAIL}`}
            class="w-full text-center px-8 py-3.5 border border-paper/20 rounded-2xl text-sm font-semibold text-paper/80 hover:border-teal/60 hover:text-paper transition-colors"
          >
            {ACQUISITION_EMAIL}
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Legal + meta -->
  <div class="max-w-6xl mx-auto px-5 sm:px-8 pb-12">
    <p class="text-[11px] leading-relaxed text-ink/45 max-w-4xl border-t border-ink/10 pt-8">
      {DISCLAIMER}
      <span class="block mt-2 text-ink/35">Information current as of July 2026.</span>
    </p>

    <div
      class="mt-8 pt-6 border-t border-ink/10 text-xs text-ink/45 flex flex-col md:flex-row gap-y-4 items-center justify-between"
    >
      <div>
        © {year} {SITE_NAME} · Educational &amp; informational · Not medical advice
      </div>
      <div class="text-[10px] text-center md:text-right">
        Transactions via Escrow.com · Clean title · Ready for transfer
      </div>
    </div>
  </div>
</footer>
