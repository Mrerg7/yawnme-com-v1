---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import {
  HERO_IMAGE_URL,
  SECONDARY_IMAGE_URL,
  SITE_NAME,
} from '../lib/constants';
import { getCollection } from 'astro:content';

const topics = await getCollection('topics');
topics.sort((a, b) => a.data.order - b.data.order);

const accentRing: Record<string, string> = {
  teal: 'accent-teal border-teal/25',
  coral: 'accent-coral border-coral/25',
  sand: 'accent-sand border-sand/30',
  sky: 'accent-sky border-sky/25',
};
---

<BaseLayout>
  <Nav />

  <main>
    <!-- Hero: full-bleed, brand-first -->
    <header
      class="hero-plane relative min-h-[100dvh] flex items-end sm:items-center pt-20"
      style={`--hero-image-url: url(${HERO_IMAGE_URL});`}
    >
      <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/35 to-ink/20" aria-hidden="true"></div>
      <div class="relative z-10 w-full max-w-6xl mx-auto px-5 sm:px-8 pb-16 sm:pb-24 pt-10">
        <p class="brand-mark text-5xl sm:text-6xl md:text-7xl text-paper animate-fade-up">
          {SITE_NAME}
        </p>
        <h1
          class="mt-4 max-w-xl font-display text-3xl sm:text-4xl md:text-[2.75rem] leading-[1.15] text-paper/95 animate-fade-up-delay"
        >
          Yawning is contagious. Here’s why.
        </h1>
        <p class="mt-4 max-w-md text-base sm:text-lg text-paper/70 leading-relaxed animate-fade-up-delay-2">
          Your brain contains a hidden network that makes you yawn when others do —
          one of the most beautiful demonstrations of human connection.
        </p>
        <div class="mt-8 flex flex-wrap gap-3 animate-fade-up-delay-2">
          <a
            href="#experience"
            class="inline-flex items-center justify-center px-7 h-12 sm:h-14 rounded-full bg-teal text-paper font-semibold text-base hover:bg-teal-deep transition-colors"
          >
            Start the Experience
          </a>
          <a
            href="#live"
            class="inline-flex items-center justify-center px-7 h-12 sm:h-14 rounded-full border border-paper/30 text-paper font-medium hover:bg-paper/10 transition-colors"
          >
            See live yawns
          </a>
        </div>
      </div>
    </header>

    <!-- Quick stats -->
    <div class="bg-mist/60 border-b border-ink/10 py-3.5">
      <div class="max-w-6xl mx-auto px-5 sm:px-8">
        <div
          class="flex flex-wrap justify-center sm:justify-between items-center gap-x-8 gap-y-2 text-sm"
        >
          <div class="flex items-center gap-x-6 text-xs">
            <div>
              <span
                class="font-mono text-teal font-semibold stat-number"
                id="global-yawns">142891</span
              >
              <span class="text-ink/45"> yawns today</span>
            </div>
            <div class="hidden sm:block h-3 w-px bg-ink/15"></div>
            <div>
              <span
                class="font-mono text-coral font-semibold stat-number"
                id="session-yawns">0</span
              >
              <span class="text-ink/45"> in this session</span>
            </div>
          </div>
          <div class="text-xs text-ink/45">
            Active across <span class="font-medium text-ink/65">148</span> countries
          </div>
        </div>
      </div>
    </div>

    <!-- Experience -->
    <section id="experience" class="max-w-6xl mx-auto px-5 sm:px-8 pt-16 pb-14">
      <div class="text-center mb-10">
        <p class="uppercase tracking-[0.2em] text-xs font-semibold text-teal mb-2">
          Interactive
        </p>
        <h2 class="section-header">Feel it happen in real time</h2>
        <p class="text-ink/55 mt-2 max-w-md mx-auto">
          Click the face below. Watch your mirror neurons respond.
        </p>
      </div>

      <div class="max-w-[620px] mx-auto">
        <button
          type="button"
          id="main-yawn-container"
          class="yawn-face relative mx-auto w-72 h-72 sm:w-80 sm:h-80 md:w-[340px] md:h-[340px] bg-paper border border-ink/12 rounded-[3.5rem] flex items-center justify-center shadow-[0_20px_50px_-24px_rgba(26,20,16,0.35)] transition-shadow hover:shadow-[0_28px_60px_-20px_rgba(13,115,119,0.25)]"
          aria-label="Trigger a yawn animation"
        >
          <svg
            id="main-yawn-svg"
            width="260"
            height="260"
            viewBox="0 0 260 260"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <circle cx="130" cy="128" r="92" fill="#e4ecee" stroke="#8a9a7b" stroke-width="12"
            ></circle>
            <g id="main-eyes">
              <ellipse cx="92" cy="105" rx="14" ry="18" fill="#12202a"></ellipse>
              <ellipse cx="168" cy="105" rx="14" ry="18" fill="#12202a"></ellipse>
              <ellipse cx="92" cy="105" rx="7" ry="9" fill="#0d7377"></ellipse>
              <ellipse cx="168" cy="105" rx="7" ry="9" fill="#0d7377"></ellipse>
            </g>
            <path
              d="M74 82 Q92 75 110 84"
              fill="none"
              stroke="#12202a"
              stroke-width="5"
              stroke-linecap="round"></path>
            <path
              d="M150 84 Q168 75 186 82"
              fill="none"
              stroke="#12202a"
              stroke-width="5"
              stroke-linecap="round"></path>
            <path
              id="main-mouth"
              d="M78 148 Q130 160 182 148"
              fill="none"
              stroke="#12202a"
              stroke-width="12"
              stroke-linecap="round"></path>
            <path
              d="M126 118 Q130 125 134 118"
              fill="none"
              stroke="#8a9a7b"
              stroke-width="2.5"
              stroke-linecap="round"></path>
          </svg>
        </button>

        <div class="text-center mt-5">
          <div id="main-status" class="text-sm text-ink/50 font-light tracking-tight">
            Your brain is ready to simulate a yawn...
          </div>
          <div id="main-count" class="font-mono text-xs mt-1 text-teal">
            Yawns triggered this session: <span class="font-semibold">0</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Science -->
    <section id="science" class="border-t border-ink/10 bg-mist/35 py-14">
      <div class="max-w-6xl mx-auto px-5 sm:px-8">
        <div class="mb-9">
          <p class="uppercase tracking-[0.18em] text-xs font-semibold text-teal">
            The science
          </p>
          <h2 class="section-header mt-1">What’s happening in your brain</h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {
            topics.map((topic) => (
              <article
                class:list={[
                  'rounded-3xl p-6 border bg-paper/70',
                  accentRing[topic.data.accent] ?? 'border-ink/10',
                ]}
              >
                <p
                  class="text-[10px] uppercase tracking-[0.18em] font-bold mb-3"
                  style="color: var(--topic-accent)"
                >
                  {topic.data.tag}
                </p>
                <h3 class="font-semibold text-lg tracking-tight mb-3">
                  {topic.data.title}
                </h3>
                <p class="text-sm text-ink/65 leading-relaxed">
                  {topic.data.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Secondary visual + animals -->
    <section class="max-w-6xl mx-auto px-5 sm:px-8 py-14 border-t border-ink/10">
      <div class="grid lg:grid-cols-12 gap-8 items-stretch">
        <div class="lg:col-span-5 relative min-h-[280px] rounded-[2rem] overflow-hidden">
          <img
            src={SECONDARY_IMAGE_URL}
            alt="Atmospheric visual for yawnme — quiet connection and rest"
            class="absolute inset-0 w-full h-full object-cover"
            loading="lazy"
            decoding="async"
            width="1200"
            height="800"
          />
          <div
            class="absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/20 to-transparent"
          >
          </div>
          <p
            class="absolute bottom-5 left-5 right-5 text-paper text-sm font-medium leading-snug"
          >
            Contagious yawning links us across species — a quiet signal of shared
            vigilance and care.
          </p>
        </div>

        <div class="lg:col-span-7">
          <p class="uppercase tracking-[0.18em] text-xs text-teal font-semibold mb-3">
            Across species
          </p>
          <h3 class="font-display text-2xl sm:text-3xl tracking-tight mb-6">
            Contagious yawning in the animal kingdom
          </h3>
          <div class="grid sm:grid-cols-2 gap-x-6 gap-y-5 text-sm">
            <div>
              <p class="font-medium">Chimpanzees &amp; Bonobos</p>
              <p class="text-xs text-ink/50 mt-0.5">Strong in-group response</p>
            </div>
            <div>
              <p class="font-medium">Dogs</p>
              <p class="text-xs text-ink/50 mt-0.5">
                Catch yawns from humans (especially owners)
              </p>
            </div>
            <div>
              <p class="font-medium">Wolves &amp; Lions</p>
              <p class="text-xs text-ink/50 mt-0.5">
                Supports group vigilance &amp; coordination
              </p>
            </div>
            <div>
              <p class="font-medium">Budgerigars</p>
              <p class="text-xs text-ink/50 mt-0.5">
                One of few birds with documented contagion
              </p>
            </div>
          </div>
          <p class="mt-8 pt-5 border-t border-ink/10 text-xs text-ink/50 leading-relaxed">
            Evolutionary purpose: synchronizing alertness and sleep/wake cycles within
            highly social groups. Early research on autism suggested reduced contagious
            yawning; newer findings show the mechanism is often intact, modulated by
            oxytocin and attention to faces.
          </p>
        </div>
      </div>
    </section>

    <!-- Live feed -->
    <section id="live" class="max-w-6xl mx-auto px-5 sm:px-8 py-14 border-t border-ink/10">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-y-4 mb-8">
        <div>
          <p class="uppercase tracking-[0.18em] text-xs font-semibold text-teal">
            Happening right now
          </p>
          <h2 class="section-header">The Global Yawn Feed</h2>
        </div>
        <button
          type="button"
          id="add-yawn-feed"
          class="self-start lg:self-auto px-5 h-10 rounded-full bg-ink/5 hover:bg-ink/10 border border-ink/10 text-sm font-medium transition-colors"
        >
          Add a yawn to the feed
        </button>
      </div>

      <div class="bg-paper border border-ink/12 rounded-3xl p-2 max-w-4xl">
        <div
          id="yawn-feed"
          class="max-h-[320px] overflow-y-auto space-y-1 p-3 text-sm"
        >
        </div>
      </div>
      <p class="text-xs text-ink/40 mt-3">
        Simulated live feed · Every yawn you trigger appears here too
      </p>
    </section>

    <!-- Quiz -->
    <section id="quiz" class="border-t border-ink/10 bg-mist/40 py-16">
      <div class="max-w-2xl mx-auto px-5 sm:px-8 text-center">
        <p class="uppercase tracking-[0.18em] text-xs font-semibold text-teal mb-2">
          Know yourself
        </p>
        <h2 class="section-header">How strong is your yawn reflex?</h2>
        <p class="text-ink/55 mt-2">
          A quick 5-question quiz that measures your susceptibility to contagious
          yawning — often a window into empathic wiring.
        </p>
        <button
          type="button"
          id="start-quiz"
          class="mt-8 px-9 h-14 rounded-full bg-ink text-paper hover:bg-ink/90 font-semibold text-lg transition-colors inline-flex items-center gap-x-3"
        >
          Start the 60-second quiz
        </button>
        <p class="text-xs text-ink/40 mt-4">Takes less than a minute · Instant results</p>
      </div>
    </section>

    <!-- Hidden hero yawn face for nav "Catch a Yawn" secondary path -->
    <div class="sr-only" aria-hidden="true">
      <div id="hero-yawn" class="yawn-face">
        <svg id="hero-yawn-svg" viewBox="0 0 320 320" width="1" height="1">
          <g id="hero-eyes"></g>
          <path id="hero-mouth" d="M112 183 Q160 194 208 183"></path>
          <path id="hero-mouth-inner" d="M124 181 Q160 189 196 181"></path>
        </svg>
      </div>
    </div>
  </main>

  <Footer />

  <!-- Quiz Modal -->
  <div
    id="quiz-modal"
    class="hidden fixed inset-0 bg-ink/60 z-[70] items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="quiz-content"
  >
    <div class="bg-paper border border-ink/12 rounded-3xl w-full max-w-lg p-8 shadow-2xl">
      <div id="quiz-content"></div>
    </div>
  </div>

  <script>
    import { initYawnme } from '../scripts/yawnme';
    initYawnme();
  </script>
</BaseLayout>
